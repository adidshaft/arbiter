{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "rootDir": "src",
    "outDir": "dist",
    "composite": true,
    "exactOptionalPropertyTypes": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node", "vitest/globals"]
  },
  "references": [{ "path": "../core" }],
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "src/**/*.test.ts", "src/**/*.spec.ts", "src/**/__tests__/**"]
}
