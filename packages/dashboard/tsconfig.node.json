{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "exactOptionalPropertyTypes": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "isolatedModules": true,
    "noEmit": true
  },
  "include": ["vite.config.ts", "tailwind.config.cjs", "postcss.config.cjs"]
}
